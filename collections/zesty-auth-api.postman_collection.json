  "info": {
    "_postman_id": "3e0176b2-6757-475c-91a7-5af921f272d4",
    "name": "Zesty Auth API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Zesty.io Auth API is used to authenticate users with the Zesty.io platform. It returns a session token that grants access to the Instances API, Accounts API, and Media API. Auth is a standalone service designed to connect to many services in the Zesty.io infrastructure. User authentication is done by providing a user account email and password combination, which issues a short-lived 30-minute session token that is extended whenever an authenticated action is taken.\n\nContact Support:\n Name: Zesty.io",
      "type": "text/plain"
    }
  }
