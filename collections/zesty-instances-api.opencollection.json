        {
          "info": {
            "name": "Zesty Update a content model",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://{instanceZUID}.api.zesty.io/v1/content/models/:modelZUID",
            "params": [
              {
                "name": "modelZUID",
                "value": "",
                "type": "path",
                "description": "The ZUID of the content model."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "apikey",
              "key": "Authorization",
              "value": "{{Authorization}}",
              "placement": "header"
            }
          },
          "docs": "Updates the details of a specific content model."
