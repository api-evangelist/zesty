        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Zesty List all content models",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{instanceZUID}.api.zesty.io/v1/content/models",
            "auth": {
              "type": "apikey",
              "key": "Authorization",
              "value": "{{Authorization}}",
              "placement": "header"
            }
          },
          "docs": "Returns a list of all content models defined in the instance."
        },
        {
          "info": {
            "name": "Zesty Create a content model",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://{instanceZUID}.api.zesty.io/v1/content/models",
            "body": {
              "type": "json",
              "data": "{}"
