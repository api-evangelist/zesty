        {
          "info": {
            "name": "Zesty Get a content model",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{instanceZUID}.api.zesty.io/v1/content/models/:modelZUID",
            "params": [
              {
                "name": "modelZUID",
                "value": "",
                "type": "path",
                "description": "The ZUID of the content model."
