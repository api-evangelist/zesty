  },
  "items": [
    {
      "info": {
        "name": "Instances",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Zesty List all instances",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://accounts.api.zesty.io/v1/instances",
            "auth": {
              "type": "apikey",
              "key": "Authorization",
              "value": "{{Authorization}}",
              "placement": "header"
            }
          },
          "docs": "Returns a list of all instances accessible to the authenticated user."
        },
        {
          "info": {
            "name": "Zesty Create a new instance",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://accounts.api.zesty.io/v1/instances",
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "apikey",
              "key": "Authorization",
              "value": "{{Authorization}}",
              "placement": "header"
            }
          },
          "docs": "Creates a new Zesty.io instance."
        },
        {
          "info": {
            "name": "Zesty Get an instance",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://accounts.api.zesty.io/v1/instances/:instanceZUID",
            "params": [
              {
                "name": "instanceZUID",
                "value": "",
                "type": "path",
                "description": "The ZUID of the instance."
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "Authorization",
              "value": "{{Authorization}}",
              "placement": "header"
            }
          },
          "docs": "Returns details for a specific instance by its ZUID."
        },
        {
          "info": {
            "name": "Zesty Update an instance",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://accounts.api.zesty.io/v1/instances/:instanceZUID",
            "params": [
              {
                "name": "instanceZUID",
                "value": "",
                "type": "path",
                "description": "The ZUID of the instance."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "apikey",
              "key": "Authorization",
              "value": "{{Authorization}}",
              "placement": "header"
            }
          },
          "docs": "Updates the details of a specific instance."
        },
        {
          "info": {
            "name": "Zesty Delete an instance",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://accounts.api.zesty.io/v1/instances/:instanceZUID",
            "params": [
              {
                "name": "instanceZUID",
                "value": "",
                "type": "path",
                "description": "The ZUID of the instance."
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "Authorization",
              "value": "{{Authorization}}",
              "placement": "header"
            }
          },
          "docs": "Deletes a specific instance."
        }
      ]
    },
